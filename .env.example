APP_ENV=development
APP_NAME=小米智能客服机器人
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
MODEL_ARTIFACT_DIR=./data/models
JWT_SECRET=replace-with-at-least-32-random-characters
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REGISTRATION_RATE_LIMIT=5
REGISTRATION_RATE_WINDOW_SECONDS=600
MAX_UPLOAD_BYTES=10485760
LLM_PROVIDER=mock
LLM_MODEL=mock-grounded-chat
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-hash-embedding
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
TOP_K=4
RERANK_CANDIDATE_K=8
RERANK_MIN_SCORE=0.65
SIMILARITY_THRESHOLD=0.25
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CORS_ORIGINS=["http://localhost:5173"]
SENSITIVE_WORDS=["支付密码","银行卡密码"]
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
INITIAL_OPERATOR_USERNAME=operator
INITIAL_OPERATOR_PASSWORD=
INITIAL_USER_USERNAME=customer
INITIAL_USER_PASSWORD=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=xiaomi-customer-service
